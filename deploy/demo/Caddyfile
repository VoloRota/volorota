# Apex serves the landing page (rendered by reset.sh with demo links)
volorota.org {
	root * /srv/landing
	file_server
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

{$DEMO_DOMAIN} {
	reverse_proxy volorota:3000
	header {
		# The session cookie's `secure` flag is left to the proxy (see src/auth.ts)
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
