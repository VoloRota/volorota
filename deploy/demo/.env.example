# Copy to .env (never commit .env) and fill in.
DEMO_DOMAIN=demo.volorota.org
VOLOROTA_ADMIN_PASSWORD=pick-the-published-demo-password

# ISC-58: optional login hint — shown beneath the sign-in form so visitors know the demo password.
# Any operator can use this env; it is not demo-specific.
VOLOROTA_LOGIN_HINT=Demo password: volorota-demo — resets every hour, so you can't break it.

# Fixed demo volunteer tokens — generate each with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# These keep the published demo links stable across hourly resets.
DEMO_TOKEN_DAVID=
DEMO_TOKEN_TOM=
DEMO_TOKEN_GRACE=
